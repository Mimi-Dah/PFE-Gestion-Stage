# ============================================================
#  StageFlow — Environment Variables Template
#  Copier ce fichier en .env et renseigner les valeurs réelles
#  NE JAMAIS committer le fichier .env
# ============================================================

# ── Django ───────────────────────────────────────────────────
# Générer une clé sécurisée : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# True en développement, False obligatoire en production
DEBUG=False

# Domaines autorisés, séparés par des virgules (ex: monsite.com,www.monsite.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# URL du frontend (utilisée dans les emails de vérification / reset)
FRONTEND_URL=http://localhost:5173

# ── Base de données MySQL / MariaDB ──────────────────────────
DB_ENGINE=django.db.backends.mysql
DB_NAME=stagepro
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=3306

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

# ── Email (SMTP) ─────────────────────────────────────────────
# En développement, laisser "console" pour afficher les emails dans le terminal
# En production, utiliser "django.core.mail.backends.smtp.EmailBackend"
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-adresse@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-application
DEFAULT_FROM_EMAIL=StageFlow <noreply@stageflow.com>

# ── Redis / Celery ───────────────────────────────────────────
# URL Redis (même valeur pour broker et result backend)
# En local : redis://127.0.0.1:6379/0
# Sur Render / Railway : valeur fournie par la plateforme
REDIS_URL=redis://127.0.0.1:6379/0

# ── CORS ─────────────────────────────────────────────────────
# Origines autorisées, séparées par des virgules
# Laisser vide en développement (autorise tout si DEBUG=True)
# En production : https://monsite.com,https://www.monsite.com
CORS_ALLOWED_ORIGINS=
