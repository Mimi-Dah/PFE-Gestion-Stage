# ---------------------------------------------------------------------------
# accounts/views.py — authentification
# ---------------------------------------------------------------------------
msgid "Token manquant."
msgstr "الرمز المميز مفقود."

msgid "Lien de vérification invalide ou déjà utilisé."
msgstr "رابط التحقق غير صالح أو تم استخدامه مسبقاً."

msgid "Compte vérifié avec succès."
msgstr "تم التحقق من الحساب بنجاح."

msgid "Email requis."
msgstr "البريد الإلكتروني مطلوب."

msgid "Si ce compte existe, un email de réinitialisation a été envoyé."
msgstr "إذا كان هذا الحساب موجوداً، فقد تم إرسال بريد إلكتروني لإعادة التعيين."

msgid "Données manquantes."
msgstr "البيانات مفقودة."

msgid "Lien invalide."
msgstr "الرابط غير صالح."

msgid "Lien de réinitialisation invalide ou expiré."
msgstr "رابط إعادة التعيين غير صالح أو منتهي الصلاحية."

msgid "Mot de passe réinitialisé avec succès."
msgstr "تمت إعادة تعيين كلمة المرور بنجاح."

msgid "Les deux mots de passe sont requis."
msgstr "كلا كلمتي المرور مطلوبتان."

msgid "Le mot de passe actuel est incorrect."
msgstr "كلمة المرور الحالية غير صحيحة."

msgid "Le nouveau mot de passe doit faire au moins 8 caractères."
msgstr "يجب أن تتكون كلمة المرور الجديدة من 8 أحرف على الأقل."

msgid "Mot de passe mis à jour avec succès."
msgstr "تم تحديث كلمة المرور بنجاح."

msgid "Rôle invalide."
msgstr "الدور غير صالح."

msgid "Vous ne pouvez pas modifier votre propre rôle."
msgstr "لا يمكنك تعديل دورك الخاص."

# ---------------------------------------------------------------------------
# accounts/views.py — langue
# ---------------------------------------------------------------------------
msgid "Langue non supportée. Choisissez parmi : %(langs)s"
msgstr "اللغة غير مدعومة. اختر من بين: %(langs)s"

msgid "Langue mise à jour avec succès."
msgstr "تم تحديث اللغة بنجاح."

# ---------------------------------------------------------------------------
# accounts/serializers.py — validation
# ---------------------------------------------------------------------------
msgid "Chef de Département must be created by an administrator."
msgstr "يجب أن يتم إنشاء حساب رئيس القسم من قبل المسؤول."

msgid "Département non trouvé."
msgstr "القسم غير موجود."

msgid "Le département %(nom)s a déjà un chef."
msgstr "القسم %(nom)s لديه رئيس بالفعل."

msgid "Ce courriel est déjà utilisé."
msgstr "البريد الإلكتروني مستخدم بالفعل."

msgid "Le mot de passe est trop court (minimum 8 caractères)."
msgstr "كلمة المرور قصيرة جداً (8 أحرف على الأقل)."

msgid "Le rôle sélectionné est invalide."
msgstr "الدور المحدد غير صالح."

# ---------------------------------------------------------------------------
# notifications/utils.py — titres et messages de notification
# ---------------------------------------------------------------------------
msgid "Nouvelle candidature reçue"
msgstr "تم استلام طلب جديد"

msgid "Votre candidature a été soumise avec succès."
msgstr "تم تقديم طلبك بنجاح."

msgid "Candidature acceptée"
msgstr "تم قبول الطلب"

msgid "Félicitations ! Votre candidature a été acceptée."
msgstr "تهانينا! تم قبول طلبك."

msgid "Candidature refusée"
msgstr "تم رفض الطلب"

msgid "Votre candidature n'a pas été retenue."
msgstr "لم يتم قبول طلبك."

msgid "Convention générée"
msgstr "تم إنشاء العقد"

msgid "Votre convention de stage est prête à être signée."
msgstr "عقد التدريب الخاص بك جاهز للتوقيع."

msgid "Convention signée"
msgstr "تم توقيع العقد"

msgid "Votre convention de stage a été signée et validée."
msgstr "تم توقيع عقد التدريب والتحقق منه."

msgid "Nouvelle absence enregistrée"
msgstr "تم تسجيل غياب جديد"

msgid "Une absence a été enregistrée pour votre stage."
msgstr "تم تسجيل غياب في تدريبك."

msgid "Nouvelle évaluation disponible"
msgstr "تقييم جديد متاح"

msgid "Votre maître de stage a soumis une évaluation."
msgstr "قدّم مشرف تدريبك تقييماً جديداً."

msgid "Rapport de stage soumis"
msgstr "تم تقديم تقرير التدريب"

msgid "Votre rapport de stage a été reçu et est en cours de traitement."
msgstr "تم استلام تقرير تدريبك وهو قيد المعالجة."

# ---------------------------------------------------------------------------
# Erreurs génériques
# ---------------------------------------------------------------------------
msgid "Une erreur inattendue s'est produite."
msgstr "حدث خطأ غير متوقع."

msgid "Accès non autorisé."
msgstr "الوصول غير مصرح به."

msgid "Ressource introuvable."
msgstr "المورد غير موجود."

msgid "Requête invalide."
msgstr "الطلب غير صالح."


# ---------------------------------------------------------------------------
# Notifications métier (absences, candidatures, conventions, évaluations, rapports)
# ---------------------------------------------------------------------------
msgid "Stage marqué comme abandonné"
msgstr "تم وضع علامة على التدريب كمتروك"

msgid "Absence clôturée — délai dépassé"
msgstr "غياب مغلق — انتهت المهلة"

msgid "Absence signalée"
msgstr "تم الإبلاغ عن غياب"

msgid "Absence à valider"
msgstr "غياب بانتظار المراجعة"

msgid "Justification à approuver"
msgstr "مبرر بانتظار المراجعة"

msgid "Justification soumise"
msgstr "تم تقديم المبرر"

msgid "Décision sur votre absence"
msgstr "قرار بشأن غيابك"

msgid "Nouvelle Candidature"
msgstr "طلب ترشح جديد"

msgid "Mise à jour de votre candidature"
msgstr "تحديث بخصوص ترشحك"

msgid "Candidature Acceptée - Action Requise"
msgstr "تم قبول الترشح - إجراء مطلوب"

msgid "Convention Expirée"
msgstr "انتهت صلاحية الاتفاقية"

msgid "Convention Expirée (Auto-Rejet)"
msgstr "انتهت صلاحية الاتفاقية (رفض تلقائي)"

msgid "Convention Validée"
msgstr "تم التحقق من الاتفاقية"

msgid "Convention Refusée"
msgstr "تم رفض الاتفاقية"

msgid "Signature Étudiant"
msgstr "توقيع الطالب"

msgid "Signature Entreprise"
msgstr "توقيع الشركة"

msgid "Évaluation Disponible"
msgstr "التقييم متاح"

msgid "Nouvelle Évaluation Déposée"
msgstr "تقييم جديد تم إيداعه"

msgid "Nouveau Rapport Soumis"
msgstr "تقرير جديد تم إيداعه"

msgid "Rapport Noté"
msgstr "تم تقييم التقرير"

msgid "acceptée"
msgstr "مقبولة"

msgid "refusée"
msgstr "مرفوضة"

msgid "mise en cours de convention"
msgstr "قيد إعداد الاتفاقية"

msgid "terminée"
msgstr "منتهية"

msgid "Votre stage pour '{offre}' a été automatiquement marqué comme abandonné suite à {count} absences non justifiées."
msgstr "تم وضع علامة على تدريبك في '{offre}' تلقائياً كمتروك بعد {count} غيابات غير مبررة."

msgid "Le stage de {etudiant} pour '{offre}' a été automatiquement marqué comme abandonné ({count} absences non justifiées)."
msgstr "تم وضع علامة على تدريب {etudiant} في '{offre}' تلقائياً كمتروك ({count} غيابات غير مبررة)."

msgid "Le délai de 3 jours pour justifier votre absence du {date} (stage '{offre}') est dépassé. Elle est désormais définitivement marquée comme non justifiée."
msgstr "انتهت مهلة الثلاثة أيام لتبرير غيابك بتاريخ {date} (تدريب '{offre}'). أصبح الآن مصنفاً بشكل نهائي على أنه غير مبرر."

msgid "Une absence a été signalée pour votre stage '{offre}' le {date}. Vous avez 3 jours pour la justifier."
msgstr "تم الإبلاغ عن غياب في تدريبك '{offre}' بتاريخ {date}. لديك 3 أيام لتبريره."

msgid "{etudiant} a été signalé absent le {date} (stage : '{offre}')."
msgstr "تم الإبلاغ عن غياب {etudiant} بتاريخ {date} (التدريب: '{offre}')."

msgid "{etudiant} a soumis une justification pour son absence du {date}. Une décision de votre part est attendue."
msgstr "قدّم {etudiant} مبرراً لغيابه بتاريخ {date}. يُنتظر قرار منكم."

msgid "{etudiant} a soumis une justification pour son absence du {date}. L'entreprise doit maintenant se prononcer."
msgstr "قدّم {etudiant} مبرراً لغيابه بتاريخ {date}. يجب على الشركة الآن اتخاذ القرار."

msgid "Votre justification pour l'absence du {date} a été approuvée par l'entreprise."
msgstr "تمت الموافقة على مبررك للغياب بتاريخ {date} من قِبل الشركة."

msgid "Votre justification pour l'absence du {date} a été refusée par l'entreprise. Cette absence est marquée comme non justifiée."
msgstr "تم رفض مبررك للغياب بتاريخ {date} من قِبل الشركة. هذا الغياب مصنف على أنه غير مبرر."

msgid "{etudiant} a postulé à votre offre '{offre}'."
msgstr "تقدّم {etudiant} بترشحه لعرضكم '{offre}'."

msgid "Une absence a été signalée pour votre stage '{offre}' le {date}."
msgstr "تم الإبلاغ عن غياب في تدريبك '{offre}' بتاريخ {date}."

msgid "Votre candidature pour '{offre}' a été {statut}."
msgstr "أصبحت حالة ترشحك لـ '{offre}' : {statut}."

msgid "La candidature de {etudiant} pour '{offre}' a été acceptée. Veuillez déposer la convention."
msgstr "تم قبول ترشح {etudiant} لـ '{offre}'. يرجى إيداع الاتفاقية."

msgid "Votre convention {numero} a été automatiquement rejetée car elle n'a pas été traitée dans le délai de 3 jours."
msgstr "تم رفض اتفاقيتك {numero} تلقائياً لعدم معالجتها خلال مهلة 3 أيام."

msgid "La convention {numero} pour {etudiant} a été rejetée automatiquement (délai de 3 jours dépassé)."
msgstr "تم رفض الاتفاقية {numero} الخاصة بـ {etudiant} تلقائياً (تجاوز مهلة 3 أيام)."

msgid "Votre convention {numero} a été validée par le département."
msgstr "تم التحقق من اتفاقيتك {numero} من قِبل القسم."

msgid "La convention {numero} ({etudiant}) a été validée."
msgstr "تم التحقق من الاتفاقية {numero} ({etudiant})."

msgid "Votre convention {numero} a été refusée. Motif : {motif}"
msgstr "تم رفض اتفاقيتك {numero}. السبب: {motif}"

msgid "La convention {numero} a été refusée par le département."
msgstr "تم رفض الاتفاقية {numero} من قِبل القسم."

msgid "L'étudiant {etudiant} a signé la convention {numero}."
msgstr "وقّع الطالب {etudiant} على الاتفاقية {numero}."

msgid "L'entreprise a signé votre convention {numero}."
msgstr "وقّعت الشركة على اتفاقيتك {numero}."

msgid "L'entreprise {entreprise} a publié votre évaluation de stage."
msgstr "نشرت الشركة {entreprise} تقييم تدريبك."

msgid "L'entreprise {entreprise} a évalué le stage de {etudiant}."
msgstr "قيّمت الشركة {entreprise} تدريب {etudiant}."

msgid "L'étudiant {etudiant} a soumis son rapport de stage pour '{offre}'."
msgstr "قدّم الطالب {etudiant} تقرير تدريبه لـ '{offre}'."

msgid "Votre rapport pour '{offre}' a été noté : {note}/20."
msgstr "تم تقييم تقريرك لـ '{offre}' بعلامة: {note}/20."

