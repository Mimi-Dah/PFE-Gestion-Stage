msgid "Votre stage pour '{offre}' a été automatiquement marqué comme abandonné suite à {count} absences non justifiées."
msgstr "Your internship for '{offre}' has been automatically marked as abandoned following {count} unjustified absences."

msgid "Le stage de {etudiant} pour '{offre}' a été automatiquement marqué comme abandonné ({count} absences non justifiées)."
msgstr "{etudiant}'s internship for '{offre}' has been automatically marked as abandoned ({count} unjustified absences)."

msgid "Le délai de 3 jours pour justifier votre absence du {date} (stage '{offre}') est dépassé. Elle est désormais définitivement marquée comme non justifiée."
msgstr "The 3-day deadline to justify your absence of {date} (internship '{offre}') has passed. It is now permanently marked as unjustified."

msgid "Une absence a été signalée pour votre stage '{offre}' le {date}. Vous avez 3 jours pour la justifier."
msgstr "An absence has been reported for your internship '{offre}' on {date}. You have 3 days to justify it."

msgid "{etudiant} a été signalé absent le {date} (stage : '{offre}')."
msgstr "{etudiant} was reported absent on {date} (internship: '{offre}')."

msgid "{etudiant} a soumis une justification pour son absence du {date}. Une décision de votre part est attendue."
msgstr "{etudiant} submitted a justification for their absence of {date}. A decision from you is expected."

msgid "{etudiant} a soumis une justification pour son absence du {date}. L'entreprise doit maintenant se prononcer."
msgstr "{etudiant} submitted a justification for their absence of {date}. The company must now decide."

msgid "Votre justification pour l'absence du {date} a été approuvée par l'entreprise."
msgstr "Your justification for the absence of {date} has been approved by the company."

msgid "Votre justification pour l'absence du {date} a été refusée par l'entreprise. Cette absence est marquée comme non justifiée."
msgstr "Your justification for the absence of {date} has been rejected by the company. This absence is marked as unjustified."

msgid "{etudiant} a postulé à votre offre '{offre}'."
msgstr "{etudiant} applied to your offer '{offre}'."

msgid "Une absence a été signalée pour votre stage '{offre}' le {date}."
msgstr "An absence has been reported for your internship '{offre}' on {date}."

msgid "Votre candidature pour '{offre}' a été {statut}."
msgstr "Your application for '{offre}' has been {statut}."

